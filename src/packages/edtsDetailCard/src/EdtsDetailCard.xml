<?xml version="1.0" encoding="utf-8"?>
<widget id="edts-mendix.edtsdetailcard.EdtsDetailCard" pluginWidget="true" needsEntityContext="true" offlineCapable="true" supportedPlatform="Web"
    xmlns="http://www.mendix.com/widget/1.0/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/@mendix/pluggable-widgets-api/widget.xsd">

    <name>EdtsDetailCard</name>
    <description>Modern detail card with current object binding and drag-and-drop sections.</description>
    <icon/>

    <properties>
        <propertyGroup caption="Content">
            <property key="eyebrowAttr" type="attribute" required="false">
                <caption>Eyebrow Attribute</caption>
                <description>Small label shown above the title.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Enum"/>
                </attributeTypes>
            </property>

            <property key="firstNameAttr" type="attribute" required="false">
                <caption>First Name Attribute</caption>
                <description>Primary first name used for the heading.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Enum"/>
                </attributeTypes>
            </property>

            <property key="lastNameAttr" type="attribute" required="false">
                <caption>Last Name Attribute</caption>
                <description>Primary last name used for the heading.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Enum"/>
                </attributeTypes>
            </property>

            <property key="titleAttr" type="attribute" required="false">
                <caption>Title Attribute Fallback</caption>
                <description>Fallback heading if first name and last name are not provided.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Enum"/>
                </attributeTypes>
            </property>

            <property key="subtitleAttr" type="attribute" required="false">
                <caption>Subtitle Attribute</caption>
                <description>Supporting subtitle shown under the title.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Enum"/>
                </attributeTypes>
            </property>

            <property key="descriptionAttr" type="attribute" required="false">
                <caption>Description Attribute</caption>
                <description>Longer supporting content shown in the body.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                </attributeTypes>
            </property>

            <property key="valueAttr" type="attribute" required="false">
                <caption>Value Attribute</caption>
                <description>Optional prominent value shown on the right side.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Integer"/>
                    <attributeType name="Long"/>
                    <attributeType name="Decimal"/>
                </attributeTypes>
            </property>

            <property key="badgeAttr" type="attribute" required="false">
                <caption>Badge Attribute</caption>
                <description>Optional badge text displayed near the value.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Enum"/>
                </attributeTypes>
            </property>

            <property key="imageUrlAttr" type="attribute" required="false">
                <caption>Image URL Attribute</caption>
                <description>Optional current object string attribute used for the image.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                </attributeTypes>
            </property>

            <property key="imageUrl" type="string" required="false">
                <caption>Image URL Fallback</caption>
                <description>Optional static image URL fallback.</description>
            </property>

            <property key="visualContent" type="widgets" required="false">
                <caption>Image Content</caption>
                <description>Optional drag-and-drop content for the image area.</description>
            </property>
        </propertyGroup>

        <propertyGroup caption="Detail Rows">
            <property key="detailItems" type="object" isList="true" required="false">
                <caption>Detail Items</caption>
                <description>Add as many detail rows as needed. Use text fallback or drag widgets into the content area.</description>
                <properties>
                    <property key="label" type="string" required="false">
                        <caption>Label</caption>
                        <category>Content</category>
                        <description>Optional row label shown above the detail value.</description>
                    </property>

                    <property key="text" type="string" required="false">
                        <caption>Fallback Text</caption>
                        <category>Content</category>
                        <description>Fallback detail text for this row.</description>
                    </property>

                    <property key="textAttr" type="attribute" required="false">
                        <caption>Fallback Text Attribute</caption>
                        <category>Content</category>
                        <description>Use a current object attribute as the fallback text for this row.</description>
                        <attributeTypes>
                            <attributeType name="String"/>
                            <attributeType name="Enum"/>
                            <attributeType name="Integer"/>
                            <attributeType name="Long"/>
                            <attributeType name="Decimal"/>
                        </attributeTypes>
                    </property>

                    <property key="icon" type="icon" required="false">
                        <caption>Icon</caption>
                        <category>Icon</category>
                        <description>Select a Mendix icon for this row.</description>
                    </property>
                </properties>
            </property>
        </propertyGroup>

        <propertyGroup caption="Appearance">
            <property key="variant" type="enumeration" required="true" defaultValue="soft">
                <caption>Variant</caption>
                <description>Select the visual treatment for the detail card.</description>
                <enumerationValues>
                    <enumerationValue key="soft">Soft</enumerationValue>
                    <enumerationValue key="outline">Outline</enumerationValue>
                    <enumerationValue key="dark">Dark</enumerationValue>
                </enumerationValues>
            </property>

            <property key="accentColor" type="string" required="false">
                <caption>Accent Color</caption>
                <description>Optional CSS color for accents and highlights.</description>
            </property>
        </propertyGroup>

        <propertyGroup caption="Actions">
            <property key="onClickAction" type="action" required="false">
                <caption>On Click</caption>
                <description>Optional action when the card is clicked.</description>
            </property>
        </propertyGroup>
    </properties>
</widget>
